<div class="col mb-4">
  <div>
    <div class="row no-gutters">
      <div class="col-md-14">
        <div class="card-body">
          <h3 class="card-title" ><a href="{{ content.link }}"> {{ content.institution }}</a></h3>
          {% if content.studyType == "Doctor of Philosophy" %}
            <h5> {{content.studyType}} in {{ content.area }}</h5>
            <h6> Advisor: <a href="https://akshatdave.github.io/">{{ content.advisor }}</a> | Lab: <a href="{{ content.lab_link }}">{{ content.lab }}</a> </h6>
          {% elsif content.studyType == "Bachelor of Science" %}
            <h5> {{content.studyType}} in {{ content.area}}</h5>
            <p>- Dean's list award recipient in 2019 - 2024</p>
            <p>- Lab coursework repository : <a href="https://github.com/SA011/BUET-Academic-Coursework">github.com/SA011/BUET-Academic-Coursework</a></p>
            <p> <b>Notable Courses:</b> {{content.courses}}</p>
          {% else %}
            <h5> {{content.studyType}} </h5>
            {% if content.scolarship == true %}
              <p>- Awarded with Talentpool Scholarship </p>
            {% endif %}
          {% endif %}
          
        </div>
      </div>
    </div>
  </div>
</div>
